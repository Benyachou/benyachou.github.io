---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article
  class="reveal surface surface-hover group flex flex-col p-6"
>
  <h3
    class="mb-2 inline-flex items-center gap-1.5 text-xl font-semibold text-white transition-colors group-hover:text-accent-300"
  >
    {project.title}
    <span
      class="translate-x-0 opacity-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100"
      aria-hidden="true"
    >→</span>
  </h3>

  <p class="mb-4 flex-1 text-sm leading-relaxed text-slate-300">
    {project.description}
  </p>

  <ul class="mb-5 flex flex-wrap gap-2">
    {
      project.stack.map((tech) => (
        <li class="rounded-md bg-accent-500/15 px-2.5 py-1 text-xs font-medium text-accent-200 ring-1 ring-accent-400/20">
          {tech}
        </li>
      ))
    }
  </ul>

  <div class="flex items-center gap-4 border-t border-white/10 pt-4 text-sm font-medium">
    <a
      href={project.repo}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-slate-200 transition-colors hover:text-accent-300"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.41 7.86 10.94.58.11.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.82 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z"
        ></path>
      </svg>
      Code
    </a>
    {
      project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-slate-200 transition-colors hover:text-accent-300"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.8"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
            />
          </svg>
          Démo
        </a>
      )
    }
  </div>
</article>

---
import Section from './Section.astro';
import { experience } from '../data/experience';
---

<Section
  id="experience"
  eyebrow="Expérience"
  title="Mon parcours professionnel"
>
  <ol class="relative ml-3 border-l-2 border-slate-200 dark:border-slate-700">
    {
      experience.map((item) => (
        <li class="reveal mb-8 ml-6 last:mb-0">
          <span
            class="absolute -left-[9px] mt-1.5 h-4 w-4 rounded-full border-2 border-white bg-accent-500 dark:border-slate-950"
            aria-hidden="true"
          />
          <p class="text-sm font-medium text-accent-600 dark:text-accent-400">
            {item.period}
          </p>
          <h3 class="mt-0.5 text-lg font-semibold text-slate-900 dark:text-white">
            {item.role}
          </h3>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            {item.company}
          </p>
          {item.description && (
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              {item.description}
            </p>
          )}
        </li>
      ))
    }
  </ol>
</Section>

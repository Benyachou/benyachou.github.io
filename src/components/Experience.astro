---
import Section from './Section.astro';
import { experience } from '../data/experience';
---

<Section
  id="experience"
  eyebrow="Expérience"
  title="Mon parcours professionnel"
>
  <ol class="relative ml-3 border-l border-white/10">
    {
      experience.map((item) => (
        <li class="reveal mb-10 ml-6 last:mb-0">
          <span
            class="absolute -left-[7px] mt-1.5 h-3.5 w-3.5 rounded-full bg-accent-400 ring-4 ring-accent-500/20"
            aria-hidden="true"
          />
          <p class="text-sm font-medium text-accent-300">
            {item.period}
          </p>
          <h3 class="mt-0.5 text-lg font-semibold text-white">
            {item.role}
          </h3>
          <p class="text-sm text-slate-400">
            {item.company}
          </p>
          {item.description && (
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-300">
              {item.description}
            </p>
          )}
        </li>
      ))
    }
  </ol>
</Section>

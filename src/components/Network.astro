---
import Section from './Section.astro';
import NetworkDiagram from './NetworkDiagram.astro';

// Principes d'architecture illustrés par la maquette — chacun s'appuie sur une
// compétence « Systèmes & réseaux » concrète.
const principles = [
  {
    title: 'Segmentation par VLAN',
    text: 'Cloisonnement des flux serveurs / utilisateurs / administration pour limiter la surface d’attaque et le périmètre des pannes.',
  },
  {
    title: 'Active Directory centralisé',
    text: 'Authentification unique, DNS, DHCP et stratégies de groupe (GPO) pour gérer le parc de façon homogène.',
  },
  {
    title: 'Virtualisation',
    text: 'Hyper-V / VMware : densité, isolation des rôles et restauration rapide via snapshots.',
  },
  {
    title: 'Pare-feu & DMZ',
    text: 'Services exposés isolés dans une DMZ derrière un pare-feu/UTM, le LAN n’est jamais directement accessible depuis Internet.',
  },
  {
    title: 'Sauvegardes 3-2-1',
    text: 'Trois copies, deux supports, une hors-site — base d’un plan de reprise d’activité fiable.',
  },
  {
    title: 'Supervision & journalisation',
    text: 'Collecte des journaux et surveillance pour détecter les incidents avant qu’ils n’impactent la production.',
  },
];
---

<Section
  id="reseau"
  eyebrow="Démonstration — Systèmes & réseaux"
  title="Architecture réseau sécurisée"
  alt={true}
>
  <p
    class="reveal mb-10 max-w-3xl text-lg leading-relaxed text-slate-600 dark:text-slate-300"
  >
    Au-delà du code, je conçois et administre des infrastructures. Voici une
    maquette d’architecture type pour une PME : segmentée, sécurisée et pensée
    pour la continuité de service. Elle illustre concrètement ma spécialité
    systèmes & réseaux.
  </p>

  <div
    class="reveal mb-10 rounded-xl border border-slate-200 bg-white p-4 sm:p-8 dark:border-slate-800 dark:bg-slate-900/60"
  >
    <NetworkDiagram />
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      principles.map((p) => (
        <div class="reveal rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900/60">
          <h3 class="mb-1.5 flex items-center gap-2 font-semibold text-slate-900 dark:text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-accent-500" />
            {p.title}
          </h3>
          <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">
            {p.text}
          </p>
        </div>
      ))
    }
  </div>
</Section>

---
import Section from './Section.astro';
import { education } from '../data/education';
---

<Section id="formation" eyebrow="Formation" title="Mes diplômes" alt={true}>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      education.map((item) => (
        <div class="reveal rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900/60">
          {item.period && (
            <p class="text-sm font-medium text-accent-600 dark:text-accent-400">
              {item.period}
            </p>
          )}
          <h3 class="mt-0.5 text-lg font-semibold text-slate-900 dark:text-white">
            {item.title}
          </h3>
          {item.school && (
            <p class="text-sm text-slate-500 dark:text-slate-400">
              {item.school}
            </p>
          )}
        </div>
      ))
    }
  </div>
</Section>

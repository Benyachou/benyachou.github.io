---
import Section from './Section.astro';
import { education } from '../data/education';
---

<Section id="formation" eyebrow="Formation" title="Mes diplômes" alt={true}>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      education.map((item) => (
        <div class="reveal surface surface-hover p-5">
          {item.period && (
            <p class="text-sm font-medium text-accent-300">
              {item.period}
            </p>
          )}
          <h3 class="mt-0.5 text-lg font-semibold text-white">
            {item.title}
          </h3>
          {item.school && (
            <p class="text-sm text-slate-400">
              {item.school}
            </p>
          )}
        </div>
      ))
    }
  </div>
</Section>

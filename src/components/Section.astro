---
/**
 * Conteneur de section réutilisable : ancre, titre et espacement cohérents.
 */
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
  /** Fond alterné pour rythmer la page. */
  alt?: boolean;
}

const { id, title, eyebrow, alt = false } = Astro.props;
---

<section
  id={id}
  class:list={[
    'scroll-mt-16 border-b border-slate-200/60 dark:border-slate-800/60',
    alt ? 'bg-slate-50 dark:bg-slate-900/40' : '',
  ]}
>
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
    <header class="reveal mb-10">
      {
        eyebrow && (
          <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-accent-600 dark:text-accent-400">
            {eyebrow}
          </p>
        )
      }
      <h2
        class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white"
      >
        {title}
      </h2>
    </header>
    <slot />
  </div>
</section>

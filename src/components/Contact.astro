---
import Section from './Section.astro';
import { site } from '../data/site';

// Formulaire sans backend via Formspree.
// → Crée un formulaire gratuit sur https://formspree.io, puis remplace
//   l'identifiant ci-dessous par le tien (ex. "xrgkabcd").
// Tant que ce n'est pas fait, le bouton « Écrire un e-mail » (mailto) reste
// pleinement fonctionnel.
const FORMSPREE_ID = 'your-form-id';
const formAction = `https://formspree.io/f/${FORMSPREE_ID}`;
---

<Section
  id="contact"
  eyebrow="Contact"
  title="Travaillons ensemble"
  alt={true}
>
  <div class="grid gap-10 md:grid-cols-2">
    <div class="reveal">
      <p class="mb-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
        Une opportunité, une question ou une envie de collaborer ? Écrivez-moi,
        je réponds rapidement.
      </p>
      <div class="space-y-3">
        <a
          href={`mailto:${site.email}`}
          class="inline-flex items-center gap-2 font-medium text-slate-700 transition-colors hover:text-accent-600 dark:text-slate-200 dark:hover:text-accent-400"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.8"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
          {site.email}
        </a>
        <br />
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-medium text-slate-700 transition-colors hover:text-accent-600 dark:text-slate-200 dark:hover:text-accent-400"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.41 7.86 10.94.58.11.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.82 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z"
            ></path>
          </svg>
          github.com/{site.github}
        </a>
      </div>
    </div>

    <form
      action={formAction}
      method="POST"
      class="reveal space-y-4 rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900/60"
    >
      <div>
        <label
          for="name"
          class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-200"
        >
          Nom
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white"
        />
      </div>
      <div>
        <label
          for="email"
          class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-200"
        >
          E-mail
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white"
        />
      </div>
      <div>
        <label
          for="message"
          class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-200"
        >
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30 dark:border-slate-700 dark:bg-slate-800 dark:text-white"
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full rounded-md bg-accent-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-600"
      >
        Envoyer
      </button>
      <p class="text-center text-xs text-slate-400 dark:text-slate-500">
        Ou écrivez-moi directement à
        <a href={`mailto:${site.email}`} class="underline hover:text-accent-500">
          {site.email}
        </a>
      </p>
    </form>
  </div>
</Section>

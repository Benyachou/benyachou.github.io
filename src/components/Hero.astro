---
import { site } from '../data/site';
import { withBase } from '../lib/path';

const cvHref = withBase(site.cvPath);
---

<section id="hero" class="relative scroll-mt-16 overflow-hidden">
  <!-- Halo bleu plus intense, localisé sur le hero (par-dessus le fond cosmique global). -->
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background:radial-gradient(60% 70% at 72% 6%, rgba(56,150,220,0.22), transparent 60%)"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-5xl px-4 pt-28 pb-24 sm:px-6 sm:pt-36 sm:pb-32">
    <p
      class="reveal mb-4 text-sm font-semibold uppercase tracking-widest text-accent-300"
    >
      {site.role}
    </p>
    <h1
      class="reveal mb-6 text-4xl font-extrabold tracking-tight text-white drop-shadow-sm sm:text-5xl md:text-6xl"
    >
      {site.name}
    </h1>
    <p class="reveal mb-10 max-w-2xl text-lg leading-relaxed text-slate-200">
      {site.tagline}
    </p>

    <div class="reveal flex flex-wrap items-center gap-3">
      <a
        href="#projets"
        class="rounded-md bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-accent-400"
      >
        Voir mes projets
      </a>
      <a
        href="#contact"
        class="rounded-md border border-white/30 px-5 py-2.5 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10"
      >
        Me contacter
      </a>
      <a
        href={cvHref}
        class="rounded-md border border-white/30 px-5 py-2.5 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:border-white hover:bg-white/10"
      >
        Télécharger le CV
      </a>
    </div>

    <div class="reveal mt-8 flex flex-wrap items-center gap-5">
      <a
        href={site.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-slate-200 transition-colors hover:text-white"
      >
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.41 7.86 10.94.58.11.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.82 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.16v3.2c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z"
          ></path>
        </svg>
        github.com/{site.github}
      </a>
      <a
        href={`mailto:${site.email}`}
        class="inline-flex items-center gap-2 text-sm font-medium text-slate-200 transition-colors hover:text-white"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.8"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
          ></path>
        </svg>
        {site.email}
      </a>
    </div>
  </div>
</section>

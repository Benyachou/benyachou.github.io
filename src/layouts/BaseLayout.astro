---
import '../styles/global.css';
import { site } from '../data/site';
import { withBase } from '../lib/path';

interface Props {
  title?: string;
  description?: string;
}

const { title = `${site.name} — ${site.role}`, description = site.description } =
  Astro.props;

const favicon = withBase('favicon.svg');

// URL canonique absolue de la page courante.
const canonical = new URL(Astro.url.pathname, site.siteUrl).href;
// Faute d'image dédiée, on réutilise le favicon. Dépose public/og-image.png
// puis utilise withBase('og-image.png') pour une vraie carte sociale.
const ogImage = new URL(favicon, Astro.site ?? site.siteUrl).href;

// Données structurées JSON-LD (Person) pour le SEO.
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: 'Développeur · Technicien Systèmes & Réseaux',
  email: `mailto:${site.email}`,
  url: site.siteUrl,
  sameAs: [site.githubUrl],
};
---

<!doctype html>
<html lang="fr" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#2e86c1" />

    <!-- Open Graph / réseaux sociaux -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link
      rel="sitemap"
      type="application/xml"
      href={withBase('sitemap-index.xml')}
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(personJsonLd)}
    />
  </head>
  <body>
    <!-- Fond cosmique fixe, derrière tout le contenu. -->
    <div class="cosmic" aria-hidden="true"></div>

    <slot />

    <!-- Apparition douce des sections au scroll (désactivée si prefers-reduced-motion). -->
    <script is:inline>
      (() => {
        const reduce = window.matchMedia(
          '(prefers-reduced-motion: reduce)',
        ).matches;
        const els = document.querySelectorAll('.reveal');
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
